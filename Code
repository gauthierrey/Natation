    async get(key) {
      var raw = localStorage.getItem("lanelog:" + key);
      if (raw === null) throw new Error("not found");
      return { key: key, value: raw, shared: false };
    },
    async set(key, value) {
      localStorage.setItem("lanelog:" + key, value);
      return { key: key, value: value, shared: false };
    },
    async delete(key) {
      localStorage.removeItem("lanelog:" + key);
      return { key: key, deleted: true, shared: false };
    },
    async list(prefix) {
      var p = "lanelog:" + (prefix || "");
